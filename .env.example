# ─── Serveur ─────────────────────────────────────────
PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# ─── Base de données PostgreSQL (Neon / Render) ──────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# ─── Authentification JWT ────────────────────────────
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=remplacez-par-une-cle-secrete-longue
JWT_EXPIRES_IN=7d

# ─── Portefeuille ────────────────────────────────────
INITIAL_WALLET_BALANCE=5000
PAYMENT_SIMULATED_SUCCESS_RATE=0.9

# ─── Sécurité API ────────────────────────────────────
CORS_ORIGIN=*
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ─── Paiements (à remplir plus tard) ─────────────────
WAVE_API_KEY=
WAVE_API_SECRET=
WAVE_WEBHOOK_SECRET=
WAVE_BASE_URL=https://api.wave.com

ORANGE_MONEY_CLIENT_ID=
ORANGE_MONEY_CLIENT_SECRET=
ORANGE_MONEY_MERCHANT_KEY=
ORANGE_MONEY_WEBHOOK_SECRET=

MTN_MONEY_API_USER=
MTN_MONEY_API_KEY=
MTN_MONEY_SUBSCRIPTION_KEY=
MTN_MONEY_WEBHOOK_SECRET=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

PAYMENT_CALLBACK_BASE_URL=https://api.taptenpass.ci
